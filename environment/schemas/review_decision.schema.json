{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewDecision",
  "type": "object",
  "required": [
    "run_id",
    "stage",
    "decision",
    "reviewer"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "stage": {"type": "string"},
    "decision": {
      "type": "string",
      "enum": ["approve", "approve_with_changes", "reject", "request_more_research", "pause"]
    },
    "reviewer": {"type": "string"},
    "required_changes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "approved_next_agent": {"type": "string"},
    "timestamp": {"type": "string"}
  }
}

